# Copy this file to `.env` on the Hetzner server and fill in real values
# before running `docker compose up -d`. Never commit the real `.env`.

# ── Postgres (container-internal — docker-compose wires these together) ──
POSTGRES_USER=degen
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=degen_warrior_site

# ── Auth ──
# Generate a real one with: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-string

# ── First admin user (created by `docker compose run --rm migrate`) ──
SEED_ADMIN_EMAIL=admin@degenwarrior.io
SEED_ADMIN_PASSWORD=replace-with-a-strong-password
